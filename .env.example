# ── DB (설계 §9) ─────────────────────────────────────────────
# Neon(Postgres) 연결 문자열. Vercel 마켓플레이스에서 Neon 연동 시 자동 주입된다.
# 로컬은 .env.local에 복사해 사용.
# 없으면 인메모리 리포지토리로 동작한다 (DB 없이 pnpm dev 가능).
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# 리포지토리 구현 강제 선택 (선택). 기본값: DATABASE_URL 있으면 drizzle, 없으면 memory.
# REPO_IMPL=memory

# ── URL (문자 QR 링크·QR 패스 페이지) ─────────────────────────
# 미설정 시 Vercel 배포 URL → http://localhost:3000 순으로 사용.
# BASE_URL=https://npr-seminar.example.com

# ── SOLAPI 문자 게이트웨이 (qr-poc 이식) ──────────────────────
# 키가 없으면 발송은 건너뛰고(스킵) 로그만 남는다 — 로컬 개발은 그대로 동작.
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=0212345678            # SOLAPI에 사전 등록된 발신번호

# 발송 스위치: 기본값은 프로덕션 배포에서만 발송. 로컬 테스트 시 SMS_ENABLED=true.
# SMS_ENABLED=true
# SMS_DISABLED=true

# 비프로덕션 오발송 방지 — 이 목록의 번호로만 발송 (쉼표 구분, 비프로덕션 기본 활성).
# SMS_RECIPIENT_ALLOWLIST=01012345678
